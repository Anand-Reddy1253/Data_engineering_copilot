{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contoso.com/schemas/pipeline",
  "title": "Contoso Pipeline Schema",
  "description": "JSON Schema for Contoso Fabric Platform pipeline YAML files",
  "type": "object",
  "required": ["name", "description", "schedule", "owner", "steps"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Pipeline name in snake_case"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable pipeline description"
    },
    "schedule": {
      "type": "string",
      "description": "Cron schedule expression (e.g. '0 6 * * *')"
    },
    "owner": {
      "type": "string",
      "description": "Team or person responsible for this pipeline"
    },
    "notifications": {
      "type": "object",
      "properties": {
        "on_failure": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {"type": "string", "enum": ["email", "teams_webhook", "slack"]},
              "recipients": {"type": "array", "items": {"type": "string"}},
              "url_env": {"type": "string"}
            }
          }
        },
        "on_success": {
          "type": "array"
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "depends_on"],
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "Step name in snake_case"
          },
          "type": {
            "type": "string",
            "enum": ["notebook", "sql", "dq_checkpoint", "notification"],
            "description": "Step type"
          },
          "notebook": {
            "type": "string",
            "description": "Path to notebook file (for type=notebook)"
          },
          "source": {
            "type": "string",
            "description": "Input data path or table"
          },
          "target": {
            "type": "string",
            "description": "Output data path or table"
          },
          "depends_on": {
            "type": "array",
            "items": {"type": "string"},
            "description": "List of step names this step depends on"
          },
          "retry_policy": {
            "type": "object",
            "properties": {
              "max_attempts": {"type": "integer", "minimum": 1, "maximum": 10},
              "backoff_seconds": {"type": "integer", "minimum": 0},
              "retry_on": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          },
          "timeout_minutes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 480,
            "description": "Step timeout in minutes"
          }
        }
      }
    }
  }
}
