{
  "expectation_suite_name": "silver_clean_transactions",
  "data_asset_type": "Dataset",
  "meta": {
    "great_expectations_version": "0.18.0",
    "notes": "Silver layer expectations for cleaned POS transactions"
  },
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 1,
        "max_value": 10000000
      },
      "meta": {"rule_type": "row_count"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "transaction_id"},
      "meta": {"rule_type": "completeness"}
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": {"column": "transaction_id"},
      "meta": {"rule_type": "uniqueness"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "store_id"},
      "meta": {"rule_type": "completeness"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "product_id"},
      "meta": {"rule_type": "completeness"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "quantity", "min_value": 1, "max_value": 10000},
      "meta": {"rule_type": "range"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "unit_price", "min_value": 0.01, "max_value": 100000},
      "meta": {"rule_type": "range"}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "payment_method",
        "value_set": ["CASH", "CARD", "DIGITAL", "VOUCHER"]
      },
      "meta": {"rule_type": "referential_integrity"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "_processed_at"},
      "meta": {"rule_type": "completeness"}
    }
  ]
}
