import os
import sys
from typing import Optional

import pyspark.sql.functions as F
from pyspark.sql import DataFrame, SparkSession

sys.path.insert(0, os.path.join(os.path.dirname(__file__), "../_shared"))
from delta_utils import upsert_to_delta
from logging_config import get_logger
from schema_registry import get_schema
from spark_session import get_spark

logger = get_logger(__name__)

SOURCE_PATH: str = os.environ.get("SOURCE_PATH", "{{SOURCE_PATH}}")
TARGET_PATH: str = os.environ.get("TARGET_PATH", "{{TARGET_PATH}}")
ENTITY: str = "{{ENTITY}}"


def ingest_{{ENTITY}}(spark: SparkSession, source_path: str, target_path: str) -> DataFrame:
    """Ingest {{ENTITY}} data from raw source to Bronze Delta table.

    Args:
        spark: Active SparkSession.
        source_path: Path to raw source files.
        target_path: Target Delta table path.

    Returns:
        DataFrame written to Delta (for validation/logging).
    """
    logger.info("Starting Bronze ingestion for %s from %s", ENTITY, source_path)

    raw_df = (
        spark.read
        .option("header", "true")
        .option("inferSchema", "false")
        .csv(source_path)
    )

    row_count = raw_df.count()
    logger.info("Read %d rows from %s", row_count, source_path)

    enriched_df = (
        raw_df
        .withColumn("_ingested_at", F.current_timestamp())
        .withColumn("_source_file", F.input_file_name())
    )

    enriched_df = enriched_df.repartition(4)

    upsert_to_delta(
        df=enriched_df,
        path=target_path,
        merge_key=["{{MERGE_KEY}}"],
    )

    logger.info("Bronze ingestion complete for %s. Rows: %d", ENTITY, row_count)
    return enriched_df


def main() -> None:
    """Entry point for Bronze ingestion notebook."""
    spark = get_spark()
    ingest_{{ENTITY}}(spark, SOURCE_PATH, TARGET_PATH)
    spark.stop()


if __name__ == "__main__":
    main()
